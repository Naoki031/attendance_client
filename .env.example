NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NUXT_PUBLIC_WS_URL=http://localhost:3001

# Firebase Web SDK (for push notifications via FCM)
# Find these values in Firebase Console → Project Settings → Your apps → Web app
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# VAPID key for Web Push — Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NUXT_PUBLIC_FIREBASE_VAPID_KEY=

# Chatbot name (used in UI) — default: HanaBot
NUXT_PUBLIC_CHATBOT_NAME="Baby Shark"