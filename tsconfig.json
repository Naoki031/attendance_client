{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "importHelpers": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"], // Map '~' to the root directory
      "@/*": ["./*"], // Map '@' to the root directory
      "#app": ["./node_modules/nuxt/dist/app"]
    },
    "types": ["@types/node", "@nuxt/types"],
    "lib": ["dom", "esnext"]
  },
  "exclude": ["node_modules", ".nuxt", "dist", "nuxt.config.ts"]
}
